generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Product {
  id        Int               @id @default(autoincrement())
  name      String
  category  String
  createdAt DateTime          @default(now())
  snapshots ProductSnapshot[]
  suppliers Supplier[]
  scripts   Script[]

  @@unique([name, category])
}

model ProductSnapshot {
  id          Int      @id @default(autoincrement())
  productId   Int
  scrapedAt   DateTime @default(now())
  ctr         Float?
  cvr         Float?
  cpa         Float?
  impressions Int?
  growthPct   Float?
  score       Float?
  product     Product  @relation(fields: [productId], references: [id])

  @@index([productId, scrapedAt])
}

model Supplier {
  id            Int      @id @default(autoincrement())
  productId     Int
  source        String
  supplierName  String?
  productTitle  String
  supplierPrice Float
  shippingDays  Int?
  moq           Int?
  productUrl    String?
  imageUrl      String?
  scrapedAt     DateTime @default(now())
  product       Product  @relation(fields: [productId], references: [id])

  @@index([productId, scrapedAt])
}

model Script {
  id        Int      @id @default(autoincrement())
  productId Int
  angle     String
  hookText  String
  bodyText  String
  ctaText   String
  hashtags  String
  createdAt DateTime @default(now())
  product   Product  @relation(fields: [productId], references: [id])
}

model Order {
  id           Int      @id @default(autoincrement())
  productName  String
  category     String
  salePrice    Float
  supplierCost Float
  shippingCost Float    @default(0)
  profit       Float
  profitMargin Float
  status       String   @default("pending")
  orderedAt    DateTime @default(now())
  notes        String?

  @@index([orderedAt])
}

model ScrapeLog {
  id         Int       @id @default(autoincrement())
  scraper    String
  status     String
  itemsFound Int?
  errorMsg   String?
  startedAt  DateTime  @default(now())
  finishedAt DateTime?
}
